# Devenv
.devenv*
devenv.local.nix
devenv.local.yaml

# direnv
.direnv

# pre-commit
.pre-commit-config.yaml


# Added by cargo

/target

# Local reference clone of external-reference — studied for architecture,
# never copied or vendored. Cloned at the project root for convenience.
/local-reference/

# Claude Code skill plumbing — local per-developer, not part of the project.
/.agents/
/skills-lock.json

# Local planning docs — kept on disk, never committed.
/UI.md
/PLAN.md

# Claude Code worktree + transcripts — per-developer state.
/.claude/

# macOS finder metadata
.DS_Store

# Bundle-time asset payload — fetched fresh from assets.openlogi.org by
# scripts/sync_bundle_assets.py before `cargo bundle`, not checked in.
/crates/openlogi-gui/assets/

# Generated app icon — built from design/icon/openlogi.svg by
# scripts/macos-icns.sh at bundle time, not checked in.
/crates/openlogi-gui/icon/

# Packaging output.
*.dmg
